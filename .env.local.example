# ─── Supabase production mode ───────────────────────────────────────────────
# 1. Copy to .env.local and fill in Supabase project values
# 2. Run migrations 001–010 in Supabase SQL editor (or: npx supabase db push)
# 3. Auth → URL config: site URL http://127.0.0.1:3001 (dev) or your production domain
# 4. npm run dev → signup → onboarding → lead intake → outreach wizard

NEXT_PUBLIC_DATA_PROVIDER=supabase
NEXT_PUBLIC_APP_MODE=production
NEXT_PUBLIC_USE_SUPABASE=true
NEXT_PUBLIC_USE_LOCAL_AUTH=false
NEXT_PUBLIC_USE_LOCAL_STORAGE=false
NEXT_PUBLIC_ENABLE_DEMO_MODE=false
NEXT_PUBLIC_ENABLE_FRESH_START=true
NEXT_PUBLIC_DEMO_MODE=false

NEXT_PUBLIC_SUPABASE_URL=https://zmsbiiyiztncynbpvctq.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Legacy name still supported:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Prisma + Supabase Postgres (server-only — replace [YOUR-PASSWORD])
# Connect → Database in the Supabase dashboard
DATABASE_URL="postgresql://postgres.zmsbiiyiztncynbpvctq:[YOUR-PASSWORD]@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.zmsbiiyiztncynbpvctq:[YOUR-PASSWORD]@aws-1-us-east-1.pooler.supabase.com:5432/postgres"

# Internet lead search (server-only — sign up at https://tavily.com)
TAVILY_API_KEY=

# ─── Vercel production (Project → Settings → Environment Variables) ────────
# Copy the block that matches how you want to run on Vercel.
#
# Option A — fresh start (no fictional demo data; use Market Search for real leads):
# NEXT_PUBLIC_DATA_PROVIDER=local
# NEXT_PUBLIC_APP_MODE=local
# NEXT_PUBLIC_USE_SUPABASE=false
# NEXT_PUBLIC_USE_LOCAL_AUTH=true
# NEXT_PUBLIC_ENABLE_DEMO_MODE=false
# NEXT_PUBLIC_DEMO_MODE=false
# NEXT_PUBLIC_ENABLE_FRESH_START=true
# TAVILY_API_KEY=<your-key>   # required for Market Search / automation internet leads
#
# Option B — live Supabase (after migrations + DB password):
# NEXT_PUBLIC_DATA_PROVIDER=supabase
# NEXT_PUBLIC_USE_SUPABASE=true
# NEXT_PUBLIC_DEMO_MODE=false
# NEXT_PUBLIC_SUPABASE_URL=https://zmsbiiyiztncynbpvctq.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<your-key>
# DATABASE_URL=<pooler-6543-url>
# DIRECT_URL=<pooler-5432-url>
# TAVILY_API_KEY=<your-key>

# Optional server-only keys (Connect dialog / API settings)
# SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_SECRET_KEY=
# SUPABASE_JWKS_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# ─── Local preview mode (no Supabase required) ─────────────────────────────
# NEXT_PUBLIC_DATA_PROVIDER=local
# NEXT_PUBLIC_APP_MODE=local
# NEXT_PUBLIC_USE_SUPABASE=false
# NEXT_PUBLIC_USE_LOCAL_AUTH=true
# NEXT_PUBLIC_ENABLE_DEMO_MODE=true
# NEXT_PUBLIC_DEMO_MODE=true
